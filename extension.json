{
  "id": "tags",
  "name": "Tags",
  "version": "0.1.0",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "users",
    "content"
  ],
  "optional_dependencies": [
    "discussions",
    "posts",
    "flags"
  ],
  "django": {
    "app_config": "bias_ext_tags.backend.apps.TagsExtensionConfig",
    "app_label": "tags",
    "migration_module": "bias_ext_tags.backend.django_migrations"
  },
  "backend": {
    "entry": "bias_ext_tags.backend.ext"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  },
  "performance_contracts": [
    {
      "name": "tag_stats_refresh",
      "message": "tag stats refresh exposes batched implementation and duration metrics.",
      "metrics": {
        "refreshed_count": "int",
        "duration_ms": "float",
        "batched": true
      },
      "tests": [
        "bias_ext_tags.backend.tests.TagExtensionTests.test_refresh_tag_stats_batches_counts_and_latest_discussions"
      ]
    }
  ],
  "security": {
    "capabilities_notice": "Taxonomy extension; owns tag records and controls tag visibility, assignment, and navigation surfaces."
  }
}
